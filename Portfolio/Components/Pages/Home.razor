@page "/"
@layout MainLayout

<PageTitle>Donna Villarin - Blooming in IT</PageTitle>

<div class="hero-section text-center">
    <div class="flower-decoration">🌸</div>
    <img class="profile-pic" src="images/donna.jpg" alt="Donna Villarin">
    <h1>✨ Hey, I'm Donna ✨</h1>
    <p class="lead">From Kinatarcan Island to the world of IT 🌊💻</p>
    <p class="story">A island girl figuring out code, one step at a time 🐚</p>
    <div class="mt-4">
        <a class="btn btn-primary me-2" href="about">💖 About Me</a>
        <a class="btn btn-secondary" href="projects">🌟 My Projects</a>
    </div>
</div>

<hr class="girly-hr" />

<section class="featured-projects">
    <h2 class="text-center">💫 What I've Been Working On 💫</h2>
    <div class="row">
        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body">
                    <div class="emoji-icon">🎀</div>
                    <h5 class="card-title">This Website</h5>
                    <p class="card-text">My personal portfolio - my biggest project so far! Learning Blazor and web development 🌐</p>
                    <a href="projects#portfolio" class="btn-sm btn-outline-pink">See more →</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body">
                    <div class="emoji-icon">🧮</div>
                    <h5 class="card-title">Calculator App</h5>
                    <p class="card-text">A simple calculator website - my first interactive JavaScript project! 🔢</p>
                    <a href="projects#calculator" class="btn-sm btn-outline-pink">See more →</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card">
                <div class="card-body">
                    <div class="emoji-icon">💬</div>
                    <h5 class="card-title">Chatbox Website</h5>
                    <p class="card-text">Working on a simple chat interface - still learning but getting there! 🗨️</p>
                    <a href="projects#chatbox" class="btn-sm btn-outline-pink">See more →</a>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="contact-cta mt-4 text-center">
    <h2>💌 Let's Connect! 💌</h2>
    <p>From Kinatarcan with love ~ <a href="contact">Say hello to me</a>!</p>
</section>